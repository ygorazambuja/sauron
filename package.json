{
	"name": "@ygorazambuja/sauron",
	"version": "1.1.5",
	"description": "OpenAPI to TypeScript/Angular Converter - Generate TypeScript interfaces and Angular HTTP services from Swagger/OpenAPI specs",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"files": [
		"bin.js",
		"dist/**/*.js",
		"src/**/*.ts",
		"!src/**/*.spec.ts",
		"!src/**/*.test.ts",
		"!src/app/sauron/**",
		"README.md",
		"docs/plugins.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"bin": {
		"sauron": "bin.js"
	},
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"start": "bun run src/index.ts",
		"dev": "bun run src/index.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"typecheck": "tsc --noEmit",
		"build": "bun build ./src/index.ts --outdir ./dist --target node --format esm",
		"build:binary": "bun build --compile ./src/index.ts --outfile sauron",
		"prepack": "bun run build",
		"cli": "bun run ./src/index.ts",
		"format": "biome check --fix"
	},
	"keywords": [
		"openapi",
		"swagger",
		"typescript",
		"angular",
		"http-client",
		"api-client",
		"code-generator"
	],
	"author": "Ygor Correa Azambuja",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ygorazambuja/sauron.git"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/bun": "^1.3.14",
		"bun-types": "^1.3.14",
		"typescript": "^7.0.2"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"jiti": "^2.7.0",
		"prettier": "^3.9.4",
		"query-string": "^9.4.1",
		"zod": "^4.4.3"
	},
	"overrides": {
		"@hono/node-server": "1.19.14",
		"express-rate-limit": "8.5.2",
		"fast-uri": "3.1.3",
		"hono": "4.12.27",
		"ip-address": "10.2.0",
		"path-to-regexp": "8.4.2",
		"qs": "6.15.3"
	}
}

{
  "name": "@ygorazambuja/sauron",
  "version": "1.1.2",
  "description": "OpenAPI to TypeScript/Angular Converter - Generate TypeScript interfaces and Angular HTTP services from Swagger/OpenAPI specs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "bin.js",
    "dist/**/*.js",
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts",
    "!src/app/sauron/**",
    "README.md",
    "docs/plugins.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sauron": "./bin.js"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm",
    "build:binary": "bun build --compile ./src/index.ts --outfile sauron",
    "prepack": "bun run build",
    "cli": "bun run ./src/index.ts",
    "format": "biome check --fix"
  },
  "keywords": [
    "openapi",
    "swagger",
    "typescript",
    "angular",
    "http-client",
    "api-client",
    "code-generator"
  ],
  "author": "Ygor Correa Azambuja",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ygorazambuja/sauron"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/bun": "^1.3.9",
    "bun-types": "^1.3.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "query-string": "^9.3.1",
    "zod": "^4.3.6"
  }
}